{
  "name": "polystella",
  "version": "0.2.0",
  "type": "module",
  "description": "AI-driven content localization for Astro (build-time markdown translation, R2-cached).",
  "license": "MIT",
  "homepage": "https://github.com/cloudflare/polystella",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/polystella.git"
  },
  "bugs": {
    "url": "https://github.com/cloudflare/polystella/issues"
  },
  "author": "Cloudflare, Inc.",
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "i18n",
    "localization",
    "translation",
    "ai",
    "cloudflare",
    "workers-ai",
    "r2"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "polystella": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    },
    "./runtime/middleware": {
      "types": "./src/runtime/middleware.ts",
      "default": "./src/runtime/middleware.ts"
    },
    "./content": {
      "types": "./src/content/index.ts",
      "default": "./src/content/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "default": "./src/i18n/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./components/LocalePicker.astro": "./components/LocalePicker.astro"
  },
  "files": [
    "src",
    "components",
    "dist",
    "client.d.ts",
    "AGENTS.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "README.md",
    "llms.txt",
    "llms-full.txt",
    "skills"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --packages=external --sourcemap=linked",
    "build:llms": "node scripts/build-llms-full.mjs",
    "prepare": "pnpm build:cli",
    "prepublishOnly": "pnpm build:cli && pnpm build:llms"
  },
  "dependencies": {
    "p-retry": "^8.0.0",
    "picomatch": "^4.0.4",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "s3mini": "^0.9.4",
    "smol-toml": "^1.6.1",
    "unified": "^11.0.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@types/mdast": "^4.0.4",
    "@types/picomatch": "^4.0.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.5.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  }
}
