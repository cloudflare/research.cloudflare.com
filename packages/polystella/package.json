{
  "name": "polystella",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "AI-driven content localization for Astro (build-time markdown translation, R2-cached).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    },
    "./content": {
      "types": "./src/content/index.ts",
      "default": "./src/content/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./components/LocalePicker.astro": "./components/LocalePicker.astro"
  },
  "files": [
    "src",
    "components"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "picomatch": "^4.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "s3mini": "^0.9.4",
    "unified": "^11.0.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/picomatch": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  }
}
