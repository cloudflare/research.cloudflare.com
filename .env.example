# Cloudflare Access Service Token for the blog mappings API.
# Allows the Astro build to fetch live pillar/tag/author data from the admin tool
# instead of the static src/data/blog-mappings.ts file.
#
# Get these from: Zero Trust > Access > Service Auth > Service Tokens
# If not set, the build falls back to blog-mappings.ts automatically.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
