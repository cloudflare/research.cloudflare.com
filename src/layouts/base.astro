---
import Footer from "../components/Footer.astro";
import TranslationNotice from "../components/TranslationNotice.astro";
import { defaultLocale, type TranslationStatus } from "@/lib/i18n-utils";
import "../styles/global.css";
import { Font } from "astro:assets";

type Props = {
  metaTitle?: string;
  metaDescription?: string;
  bodyClassName?: string;
  /**
   * Page's translation provenance. Drives the AI-translation banner +
   * footer badge. Pages with a primary localized entry pass the
   * precise value computed via `computeTranslationStatus`; otherwise
   * defaults to `"ai"` for non-default locales, `"source"` otherwise.
   */
  aiTranslationStatus?: TranslationStatus;
};

const { metaTitle, metaDescription, bodyClassName = "", aiTranslationStatus } = Astro.props;

const currentLocale = Astro.currentLocale ?? defaultLocale;
const isNonDefaultLocale = currentLocale !== defaultLocale;
const resolvedTranslationStatus = aiTranslationStatus ?? (isNonDefaultLocale ? "ai" : "source");
const showTranslationNotice = resolvedTranslationStatus === "ai";
---

<html lang={currentLocale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>
      {metaTitle ? metaTitle + " | Cloudflare Research" : "Cloudflare Research"}
    </title>
    <!-- meta description -->
    {metaDescription && <meta name="description" content={metaDescription} />}
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- OG -->
    <meta property="og:title" content={metaTitle ? metaTitle + " | Cloudflare Research" : "Cloudflare Research"} />
    {metaDescription && <meta property="og:description" content={metaDescription} />}
    <meta property="og:image" content="/images/og.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Cloudflare Research" />
    <meta property="og:image:type" content="image/jpeg" />

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-roboto-mono" preload />

    {
      /*
       * Translation-notice anti-flash. Runs synchronously before any
       * body content paints; reads localStorage and sets
       * `data-translation-notice="dismissed"` on `<html>` if the
       * visitor has previously dismissed the banner for this locale.
       * The CSS rule in `global.css` then hides `.translation-banner`
       * before its first paint. Pair: dismiss handler in
       * `TranslationNotice.astro`. Version literal `v1` must match
       * that file's `NOTICE_VERSION`.
       *
       * Only injected on non-default locales — default locale never
       * shows the banner, so the read would be wasted work.
       */
    }
    {/* Anti-flash for the translation notice; pairs with TranslationNotice.astro */}
    {
      isNonDefaultLocale && (
        <script is:inline define:vars={{ locale: currentLocale, version: "v1" }}>
          try {
            if (localStorage.getItem("polystella:notice:" + locale + ":" + version) === "dismissed") {
              document.documentElement.dataset.translationNotice = "dismissed";
            }
          } catch (e) {}
        </script>
      )
    }

    <slot name="head" />
  </head>
  <body class={bodyClassName || ""}>
    <main class={`w-full max-w-page mx-auto ${bodyClassName !== "home" ? "md:dashed-borders" : ""}`}>
      <slot />
      <Footer aiTranslationStatus={resolvedTranslationStatus} />
    </main>
    {showTranslationNotice && <TranslationNotice />}
  </body>
</html>
