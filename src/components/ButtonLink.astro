---
import { cva, type VariantProps } from "class-variance-authority";

const buttonLinkClassNames = cva(
  "inline-block border font-mono leading-6 px-2 rounded-[4px] font-mono text-xs",
  {
    variants: {
      variant: {
        default: "border-page-border-subtle text-page-text",
      },
    },
    defaultVariants: {
      variant: "default",
    },
  }
);

type ButtonLinkProps = VariantProps<typeof buttonLinkClassNames> & {
  href: string;
};

const { href, variant } = Astro.props as ButtonLinkProps;

---

<a href={href} class="border-2 border-blue rounded-full inline-block hover:border-portage group/cta">
  <div class="bg-blue rounded-full py-4 px-6 text-white m-1 font-bold group-hover/cta:bg-portage flex items-center gap-1"><slot /></div>
</a>