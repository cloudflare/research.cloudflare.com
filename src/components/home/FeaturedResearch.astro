---
import SeeMore from "../SeeMore.astro";
import { getLocalizedEntry } from "@cloudflare/polystella/runtime";
const { t } = Astro.locals;

// `site.toml` produces a single `main` entry under Astro's `file()`
// loader. PolyStella stages translated TOML at
// `<staging>/<locale>/site.toml`; `getLocalizedEntry` dispatches to
// the locale's sibling collection (`site__pt-BR` / `site__ja-JP`)
// and falls back to the source on the default locale or a miss.
const siteEntry = await getLocalizedEntry("site", "main", Astro.currentLocale);

const { title, description, link, buttonLabel } = siteEntry!.data.featuredResearch;
---

<section class="interior-content border-b-2 border-page-border connector-bl connector-br">
  <div class="relative">
    <picture>
      <source srcset="/images/connector.svg" media="(prefers-color-scheme: dark)" />
      <img src="/images/connector--light.svg" alt="" class="absolute -bottom-[7px] -right-[7px]" width="12" height="12" />
    </picture>
  </div>
  <div class="px-8 md:px-4 lg:px-12 py-10">
    <div class="font-mono text-sm text-stack mb-4">
      {t("home.featured.label")}
    </div>
    <a href={link} class="mb-8 block group/link">
      <h1 class="heading inline group-hover/link:text-blue text-2xl sm:text-3xl lg:text-4xl">
        {title}
      </h1>
    </a>
    <p>{description}</p>
    <SeeMore href={link}>{buttonLabel}</SeeMore>
  </div>
  <div class="relative">
    <picture>
      <source srcset="/images/connector.svg" media="(prefers-color-scheme: dark)" />
      <img src="/images/connector--light.svg" alt="" class="absolute -bottom-[7px] -left-[7px]" width="12" height="12" />
    </picture>
  </div>
</section>
