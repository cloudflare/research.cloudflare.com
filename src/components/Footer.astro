---
import { CONSTANTS } from "../lib/constants";
import Icon from "./Icon.astro";
import { useTranslations } from "polystella/ui";

const t = await useTranslations(Astro.currentLocale);
---

<footer class="pt-11">
  <!-- Main footer content -->
  <div class="pb-[60px] px-8">
    <nav
      class="grid grid-cols-1 gap-20 sm:grid-cols-3 xl:grid-cols-[250px_1fr_1fr_1fr_1.1fr] gap-x-8"
    >
      <!-- Logo section -->
      <div class="sm:row-span-2 xl:row-span-1">
        <a href="/">
          <picture>
            <source
              srcset="/images/logo.svg"
              media="(prefers-color-scheme: dark)"
            />
            <img
              src="/images/logo--light.svg"
              alt="Cloudflare Research"
              width="197"
              height="53"
            />
          </picture>
        </a>
      </div>

      <!-- Focus Areas -->
      <div>
        <h3>{t("footer.focusAreas")}</h3>
        <hr />
        <ul>
          <li>
            <a href="/focus/private">{t("footer.focusAreas.morePrivate")}</a>
          </li>
          <li><a href="/focus/safe">{t("footer.focusAreas.safer")}</a></li>
          <li><a href="/focus/fast">{t("footer.focusAreas.faster")}</a></li>
          <li>
            <a href="/focus/reliable">{t("footer.focusAreas.moreReliable")}</a>
          </li>
          <li>
            <a href="/focus/measurable"
              >{t("footer.focusAreas.moreMeasurable")}</a
            >
          </li>
        </ul>
      </div>

      <!-- Outreach -->
      <nav>
        <h3>{t("footer.outreach")}</h3>
        <hr />
        <ul>
          <li>
            <a href="/presentations">{t("footer.outreach.presentations")}</a>
          </li>
        </ul>
      </nav>

      <!-- About Us -->
      <div>
        <h3>{t("footer.aboutUs")}</h3>
        <hr />
        <ul>
          <li><a href="/people">{t("footer.aboutUs.people")}</a></li>
          <li><a href="/philosophy">{t("footer.aboutUs.philosophy")}</a></li>
        </ul>
      </div>

      <!-- Careers -->
      <div>
        <h3>{t("footer.careers")}</h3>
        <hr />
        <ul>
          <li>
            <a
              href={CONSTANTS.CLOUDFLARE_CAREERS}
              target="_blank"
              rel="noopener noreferrer"
              class="text-page-text-muted text-base hover:text-page-text transition-colors group/footer"
            >
              <span class="inline">{t("footer.careers.inResearch")}</span>
              <Icon id="arrowUpRight" class="inline external-arrow" />
            </a>
          </li>
          <li>
            <a
              href={CONSTANTS.CLOUDFLARE_JOBS}
              target="_blank"
              rel="noopener noreferrer"
              class="text-page-text-muted text-base hover:text-page-text transition-colors group/footer"
            >
              <span class="inline">{t("footer.careers.allOpenRoles")}</span>
              <Icon id="arrowUpRight" class="inline external-arrow" />
            </a>
          </li>
          <li>
            <a
              href={CONSTANTS.CLOUDFLARE_CAREERS}
              target="_blank"
              rel="noopener noreferrer"
              class="text-page-text-muted text-base hover:text-page-text transition-colors group/footer"
            >
              {t("footer.careers.workingAt")}
              <Icon id="arrowUpRight" class="inline external-arrow" />
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <!-- Legal -->
  <div
    class="flex flex-col sm:flex-row sm:justify-between sm:items-center sm:gap-4 text-page-text-muted border-t border-page-border pt-4 pb-5 px-8
    [&_a]:text-page-text-muted [&_a]:text-sm] [&_a:hover]:text-page-text [&_a:hover]:underline"
  >
    <div class="text-left">
      {t("footer.legal.copyright", { year: new Date().getFullYear() })}
    </div>
    <div class="text-left sm:text-right">
      <a href={CONSTANTS.PRIVACY_POLICY}>{t("footer.legal.privacyPolicy")}</a> . <a
        href={CONSTANTS.TERMS_OF_SERVICE}>{t("footer.legal.terms")}</a
      > . <a href={CONSTANTS.GDPR}>{t("footer.legal.gdpr")}</a>
    </div>
  </div>
</footer>
