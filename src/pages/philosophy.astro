---
import { render } from "astro:content";
import { getLocalizedEntry } from "@cloudflare/polystella/runtime";

import HeaderPhilosophy from "@/components/HeaderPhilosophy.astro";
import InteriorLayout from "@/layouts/interior.astro";
import { computeTranslationStatus } from "@/lib/i18n-utils";

// Thin wrapper around `src/content/pages/philosophy.mdx`. The MDX file
// owns the prose; this file owns the localised header + page chrome
// and orchestrates the locale-aware entry lookup.
const entry = await getLocalizedEntry("pages", "philosophy", Astro.currentLocale);
if (!entry) {
  throw new Error("[philosophy] missing content/pages/philosophy.mdx entry");
}
const { Content } = await render(entry);
const aiTranslationStatus = computeTranslationStatus(Astro.currentLocale, entry);
---

<InteriorLayout metaTitle={entry.data.title} aiTranslationStatus={aiTranslationStatus}>
  <HeaderPhilosophy />
  <div class="[&_h2]:heading-label [&_h2]:mb-4">
    <Content />
  </div>
</InteriorLayout>
