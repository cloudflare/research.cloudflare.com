---
import { render } from "astro:content";
import { getLocalizedEntry } from "polystella/runtime";

import HeaderPhilosophy from "@/components/HeaderPhilosophy.astro";
import InteriorLayout from "@/layouts/interior.astro";

// Thin wrapper around `src/content/pages/philosophy.mdx`. The MDX
// file owns the prose and per-section layout (Section / NarrowContent
// wrappers); this file owns chrome (the localised header, the
// outer page layout) and orchestrates the locale-aware entry lookup.
//
// `<HeaderPhilosophy />` stays here (not in the MDX) because its
// title/subtitle come from the UI-strings system, not from prose
// translation. Same reasoning for `metaTitle` / `metaDescription`:
// short, slow-changing strings that already live in the UI-strings
// pipeline. The MDX's own frontmatter `metaTitle` is used as a
// fallback when a translation has been produced.
const entry = await getLocalizedEntry("pages", "philosophy", Astro.currentLocale);
if (!entry) {
  throw new Error("[philosophy] missing content/pages/philosophy.mdx entry");
}
const { Content } = await render(entry);
---

<InteriorLayout metaTitle={entry.data.title}>
  <HeaderPhilosophy />
  <div class="[&_h2]:heading-label [&_h2]:mb-4">
    <Content />
  </div>
</InteriorLayout>
